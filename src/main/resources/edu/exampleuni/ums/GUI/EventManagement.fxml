<?xml version="1.0" encoding="UTF-8"?>

<?import edu.exampleuni.ums.GUI.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.cell.*?>

<fx:root type="javafx.scene.layout.VBox" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
	<padding>
		<Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
	</padding>
	<Label text="Event Management">
		<font>
			<Font name="Arial Bold" size="24.0" />
		</font>
	</Label>
	<HBox alignment="CENTER_LEFT" spacing="10.0">
		<TextField prefWidth="300.0" promptText="Search events..." />
		<Spacer />
		<Button fx:id="addButton" styleClass="addButton" text="Add Event" />
	</HBox>
	<TableView fx:id="eventTable" VBox.vgrow="ALWAYS">
		<columns>
			<TableColumn prefWidth="100.0" text="Event Code" ><cellValueFactory><PropertyValueFactory property="code" /></cellValueFactory></TableColumn>
			<TableColumn prefWidth="150.0" text="Event Name" ><cellValueFactory><PropertyValueFactory property="eventName" /></cellValueFactory></TableColumn>
			<TableColumn prefWidth="100.0" text="capacity" ><cellValueFactory><PropertyValueFactory property="capacity" /></cellValueFactory></TableColumn>
			<TableColumn prefWidth="100.0" text="cost" ><cellValueFactory><PropertyValueFactory property="cost" /></cellValueFactory></TableColumn>
			<TableColumn prefWidth="150.0" text="description" ><cellValueFactory><PropertyValueFactory property="description" /></cellValueFactory></TableColumn>
			<!--todo location-->
			<!--todo time-->
			<!--<TableColumn prefWidth="150.0" text="Admin Actions"/>-->
		</columns>
	</TableView>
</fx:root>
