<?xml version="1.0" encoding="UTF-8"?>


<?import edu.exampleuni.ums.*?>
<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.cell.*?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
	<padding>
		<Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
	</padding>
	<Label text="Course Management">
		<font>
			<Font name="Arial Bold" size="24.0" />
		</font>
	</Label>
	<Label text="Under construction" />
	<TabPane tabClosingPolicy="UNAVAILABLE">
		<Tab text="All Courses">
			<VBox spacing="10.0">
				<padding>
				   <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
				</padding>
				<HBox alignment="CENTER_LEFT" spacing="10.0">
					<TextField prefWidth="300.0" promptText="Search courses..." />
					<ComboBox promptText="Filter by Subject">
						<items>
							<FXCollections fx:factory="observableArrayList">
								<String fx:value="All Subjects" />
								<String fx:value="Mathematics" />
								<String fx:value="Computer Science" />
								<String fx:value="English" />
								<String fx:value="Biology" />
								<String fx:value="Physics" />
							</FXCollections>
						</items>
						<value>
							<String fx:value="All Subjects" />
						</value>
					</ComboBox>
					<Spacer />
					<Button styleClass="addButton" text="Add Course" />
				</HBox>
				<TableView VBox.vgrow="ALWAYS">
					<columns>
						<TableColumn prefWidth="100.0" text="Course Code" ><cellValueFactory><PropertyValueFactory property="code" /></cellValueFactory></TableColumn>
						<TableColumn prefWidth="200.0" text="Course Name" ><cellValueFactory><PropertyValueFactory property="courseName" /></cellValueFactory></TableColumn>
						<TableColumn prefWidth="150.0" text="Subject" ><cellValueFactory><PropertyValueFactory property="subject" /></cellValueFactory></TableColumn>
						<TableColumn prefWidth="80.0" text="Section" ><cellValueFactory><PropertyValueFactory property="section" /></cellValueFactory></TableColumn>
						<TableColumn prefWidth="150.0" text="Teacher" ><cellValueFactory><PropertyValueFactory property="teacher" /></cellValueFactory></TableColumn>
						<TableColumn prefWidth="80.0" text="Capacity" ><cellValueFactory><PropertyValueFactory property="capacity" /></cellValueFactory></TableColumn>
						<TableColumn prefWidth="100.0" text="Location" ><cellValueFactory><PropertyValueFactory property="location" /></cellValueFactory></TableColumn>
						<TableColumn prefWidth="150.0" text="Admin Actions" ><cellValueFactory><PropertyValueFactory property="location" /></cellValueFactory></TableColumn>
					</columns>
					<items>
						<FXCollections fx:factory="observableArrayList">
							<Course code="CS101" courseName="Introduction to Programming" subject="Computer Science" section="Section 1" teacher="Dr. Smith" capacity="30" location="Room 101"/>
							<Course code="MATH101" courseName="Calculus I" subject="Mathematics" section="Section 1" teacher="Dr. Johnson" capacity="35" location="Room 202"/>
							<Course code="ENG201" courseName="Advanced Composition" subject="English" section="Section 2" teacher="Prof. Williams" capacity="25" location="Room 303"/>
							<Course code="BIO101" courseName="Introduction to Biology" subject="Biology" section="Section 1" teacher="Dr. Brown" capacity="40" location="Lab 1"/>
							<Course code="PHYS101" courseName="Physics I" subject="Physics" section="Section 3" teacher="Dr. Davis" capacity="30" location="Room 405"/>
						</FXCollections>
					</items>
				</TableView>
			</VBox>
		</Tab>
		<Tab text="Admin Schedule" />
		<Tab text="Admin Enrollments" />
		<Tab text="User My Courses" />
	</TabPane>
</VBox>
