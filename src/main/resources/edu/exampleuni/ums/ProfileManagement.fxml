<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox id="content" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <Label id="titleLabel" text="Profile Management">
        <font>
          <Font name="Arial Bold" size="24.0" />
        </font>
    </Label>
    <GridPane id="profileGrid" hgap="20.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
        <VBox spacing="10.0" GridPane.halignment="CENTER" GridPane.rowSpan="5" GridPane.valignment="CENTER">
            <StackPane id="avatarPane" prefHeight="120.0" prefWidth="120.0" style="-fx-background-color: #f0f0f0; -fx-background-radius: 60;">
                <Label id="avatarLabel" text="JD" textFill="#808080">
                    <font>
                        <Font name="Arial Bold" size="36.0" />
                    </font>
                </Label>
            </StackPane>
            <Button id="uploadPhotoBtn" mnemonicParsing="false" style="-fx-text-fill: white; -fx-background-color: #3498db;" text="Upload Photo" />
        </VBox>
        <Label text="Name:" GridPane.columnIndex="1" />
        <Label text="ID:" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <Label text="Email:" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        <Label text="Address:" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        <Label text="Phone:" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        <Label text="John Doe" GridPane.columnIndex="2" />
        <Label text="STU1234567" GridPane.columnIndex="2" GridPane.rowIndex="1" />
        <Label text="john.doe@university.eduLabel" GridPane.columnIndex="2" GridPane.rowIndex="2" />
        <Label text="123 Campus Drive, University City" GridPane.columnIndex="2" GridPane.rowIndex="3" />
        <Label text="(555) 123-4567" GridPane.columnIndex="2" GridPane.rowIndex="4" />
    </GridPane>
    <TitledPane id="changePasswordPane" text="Change Password">
        <GridPane id="passwordGrid" hgap="10.0" vgap="10.0">
            <columnConstraints>
                <ColumnConstraints />
                <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label text="Current Password:" />
            <Label text="New Password:" GridPane.rowIndex="1" />
            <Label text="Confirm Password:" GridPane.rowIndex="2" />
            <Button style="-fx-text-fill: white; -fx-background-color: #3498db;" text="Update Password" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <PasswordField GridPane.columnIndex="1" />
            <PasswordField GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <PasswordField GridPane.columnIndex="1" GridPane.rowIndex="2" />
        </GridPane>
    </TitledPane>
</VBox>
